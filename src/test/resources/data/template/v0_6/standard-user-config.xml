<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- List of tags to transform -->
    <tag-list>
        <tag key="operator" />
        <tag key="ref" />
        <tag key="tunnel:name" />
        <tag key="bridge:name" />
        <tag key="name" />
        <tag key="name:en" />
        <tag key="name:ja" />
        <tag key="name:ja-Hira" />
        <tag key="alt_name" />
        <tag key="brand:ja" />
        <tag key="brand" />
    </tag-list>
    <!-- List of manual character replacements -->
    <replacement-list>
        <replace-with value="">
            <when-value-is value="" />
            <when-value-is value="" />
        </replace-with>

        <replace-with value="·">
            <when-value-is value="・" />
            <when-value-is value="･" />
            <when-value-is value="•" />
        </replace-with>

        <replace-with value="&lt;">
            <when-value-is value="〈" />
        </replace-with>

        <replace-with value="&lt;&lt;">
            <when-value-is value="《" />
        </replace-with>

        <replace-with value="&gt;">
            <when-value-is value="〉" />
        </replace-with>

        <replace-with value="&gt;&gt;">
            <when-value-is value="》" />
        </replace-with>

        <replace-with value="'">
            <when-value-is value="ʻ" />
        </replace-with>

        <replace-with value="-">
            <when-value-is value="–" />
        </replace-with>
    </replacement-list>

</configuration>
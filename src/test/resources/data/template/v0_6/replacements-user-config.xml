<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <replacement-list>
        <replace-with value="">
            <when-value-is value="" />
            <when-value-is value="" />
        </replace-with>

        <replace-with value="·">
            <when-value-is value="・" />
            <when-value-is value="･" />
            <when-value-is value="•" />
        </replace-with>

        <replace-with value="&lt;">
            <when-value-is value="〈" />
        </replace-with>

        <replace-with value="&lt;&lt;">
            <when-value-is value="《" />
        </replace-with>

        <replace-with value="&gt;">
            <when-value-is value="〉" />
        </replace-with>

        <replace-with value="&gt;&gt;">
            <when-value-is value="》" />
        </replace-with>

        <replace-with value="'">
            <when-value-is value="ʻ" />
        </replace-with>

        <replace-with value="-">
            <when-value-is value="–" />
        </replace-with>
    </replacement-list>
</configuration>
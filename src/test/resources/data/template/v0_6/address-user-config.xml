<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- List of dictionaries to use -->
    <dictionary-list>
        <dictionary alias="station" />
        <dictionary alias="geo" />
        <dictionary alias="propernoun" />
    </dictionary-list>
    <!-- List of tags to transform -->
    <tag-list>
        <tag key="addr:city" />
        <tag key="addr:province" />
        <tag key="addr:block_number" />
        <tag key="addr:neighbourhood" />
        <tag key="addr:postcode" />
        <tag key="addr:housenumber" />
        <tag key="addr:quarter" />
        <tag key="addr:full" />
        <tag key="addr:suburb" />
        <tag key="addr:country" />
        <tag key="addr:street" />
        <tag key="addr:county" />
        <tag key="addr:housename" />
        <tag key="addr:floor" />
        <tag key="addr:place" />
        <tag key="addr:flats" />
        <tag key="addr:room" />
        <tag key="addr:prefecture" />
        <tag key="addr:unit" />
        <tag key="addr:block" />
        <tag key="addr:district" />
        <tag key="addr:all" />
        <tag key="addr:state" />
        <tag key="addr:pref" />
        <tag key="addr:hamlet" />
        <tag key="addr:region" />
        <tag key="addr:neighborhood" />
        <tag key="addr:subdistrict" />
        <tag key="addr:town" />
    </tag-list>
    <!-- List of manual character replacements -->
    <replacement-list>
        <replace-with value="">
            <when-value-is value="" />
            <when-value-is value="" />
        </replace-with>

        <replace-with value="·">
            <when-value-is value="・" />
            <when-value-is value="･" />
            <when-value-is value="•" />
        </replace-with>

        <replace-with value="&lt;">
            <when-value-is value="〈" />
        </replace-with>

        <replace-with value="&lt;&lt;">
            <when-value-is value="《" />
        </replace-with>

        <replace-with value="&gt;">
            <when-value-is value="〉" />
        </replace-with>

        <replace-with value="&gt;&gt;">
            <when-value-is value="》" />
        </replace-with>

        <replace-with value="'">
            <when-value-is value="ʻ" />
        </replace-with>

        <replace-with value="-">
            <when-value-is value="–" />
        </replace-with>
    </replacement-list>

</configuration>